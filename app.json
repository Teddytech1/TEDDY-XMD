{
  "name": "TEDDY-XMD",
  "description": "TEDDY-XMD — A Powerful WhatsApp Bot built with Node.js.",
  "repository": "https://github.com/Teddytech1/TEDDY-XMD",
  "logo": "https://files.catbox.moe/13nyhx.jpg",
  "keywords": ["whatsapp", "bot", "baileys", "node"],
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID. TEDDY-XMD:~:~<base64>",
      "required": true
    }
  },
  "formation": {
    "web": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    { "plan": "heroku-postgresql" }
  ],
  "scripts": {
    "start": "node index.js"
  },
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" },
    { "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git" }
  ]
}
