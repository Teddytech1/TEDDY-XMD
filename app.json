{
  "name": "teddy-xmd",
  "description": "TEDDY-XMD — A Powerful WhatsApp Bot built with Node.js.",
  "repository": "https://github.com/Teddytech1/TEDDY-XMD",
  "logo": "https://files.catbox.moe/j35jos.jpg",
  "keywords": ["whatsapp", "bot", "baileys", "node", "teddy-xmd"],
  "stack": "container",
  "env": {
    "SESSION_ID": {
      "description": "Your WhatsApp session ID. Teddy:~<base64>",
      "required": true
    },
    "PREFIX": {
      "description": "Bot command prefix",
      "value": ".",
      "required": true
    },
    "BOT_NAME": {
      "description": "Bot display name",
      "value": "TEDDY-XMD",
      "required": false
    }
  },
  "formation": {
    "worker": {
      "quantity": 1,
      "size": "basic"
    }
  },
  "addons": [
    { "plan": "heroku-postgresql:hobby-dev" }
  ],
  "scripts": {
    "postdeploy": "npm install --legacy-peer-deps"
  },
  "buildpacks": [
    { "url": "heroku/nodejs" },
    { "url": "https://github.com/DuckyTeam/heroku-buildpack-imagemagick.git" },
    { "url": "https://github.com/jonathanong/heroku-buildpack-ffmpeg-latest" },
    { "url": "https://github.com/clhuang/heroku-buildpack-webp-binaries.git" }
  ]
}
